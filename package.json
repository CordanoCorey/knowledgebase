{
  "name": "convex-collaborative-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "build:component": "vite build --config vite.component.config.ts",
    "build:static": "npm run build && npm run build:component",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy --cmd \"npm run build:static\"",
    "seed:scripture": "node scripts/seed-scripture.mjs"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@convex-dev/auth": "^0.0.94",
    "@convex-dev/prosemirror-sync": "^0.2.4",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@vitejs/plugin-react": "latest",
    "convex": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "convex-test": "^0.0.53",
    "happy-dom": "^20.10.2",
    "typescript": "latest",
    "vitest": "^4.1.8"
  }
}
